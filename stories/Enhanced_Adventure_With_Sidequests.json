  "quest_npcs": {
    "npc_gareth": {
      "id": "npc_gareth",
      "name": "Master Gareth",
      "title": "Village Blacksmith",
      "location": "village_blacksmith",
      "description": "A weathered dwarf with calloused hands and kind eyes. His workshop rings with the sound of hammer on anvil.",
      "dialogue_states": {
        "default": {
          "text": "Welcome to my forge, traveler. I craft the finest weapons in all of Aldermere.",
          "options": [
            { "text": "Show me your wares", "action": "shop", "requires": {} },
            { "text": "Tell me about yourself", "action": "info", "requires": {} },
            { "text": "Goodbye", "action": "leave", "requires": {} }
          ]
        },
        "blacksmith_apprentice_available": {
          "text": "Ah, you look like someone who could help an old smith. My grandfather's hammer... it was stolen by those cursed goblins!",
          "options": [
            { "text": "I'll help you recover it", "action": "accept_quest", "quest": "blacksmith_apprentice" },
            { "text": "Tell me more about this hammer", "action": "quest_info", "quest": "blacksmith_apprentice" },
            { "text": "I'm not interested", "action": "decline_quest", "requires": {} }
          ]
        },
        "blacksmith_apprentice_active": {
          "text": "Have you found any trace of my hammer? The goblins have a cave somewhere in the Dark Forest.",
          "options": [
            { "text": "Still searching", "action": "continue", "requires": {} },
            { "text": "Where exactly is this cave?", "action": "quest_hint", "requires": {} }
          ]
        },
        "blacksmith_apprentice_completed": {
          "text": "You've returned my grandfather's hammer! I am forever in your debt. Please, take this sword I forged with the old techniques.",
          "options": [
            { "text": "Thank you for the reward", "action": "complete_quest", "quest": "blacksmith_apprentice" },
            { "text": "Can you teach me smithing?", "action": "unlock_training", "requires": { "story_flags": ["smithing_knowledge"] } }
          ]
        }
      }
    },

    "merchant_valdris": {
      "id": "merchant_valdris",
      "name": "Valdris the Trader",
      "title": "Traveling Merchant",
      "location": "village_gates",
      "description": "A well-dressed human with nervous eyes, constantly checking his valuable cargo wagon.",
      "dialogue_states": {
        "default": {
          "text": "The roads grow more dangerous each day. I fear for my cargo and my life.",
          "options": [
            { "text": "What goods do you carry?", "action": "shop", "requires": {} },
            { "text": "What troubles you?", "action": "info", "requires": {} }
          ]
        },
        "merchant_caravan_available": {
          "text": "You look capable with that sword. I need protection for my journey to Millbrook. The pay is good, but the danger is real.",
          "options": [
            { "text": "I'll escort your caravan", "action": "accept_quest", "quest": "merchant_caravan" },
            { "text": "What's the route like?", "action": "quest_info", "quest": "merchant_caravan" },
            { "text": "Find someone else", "action": "decline_quest", "requires": {} }
          ]
        }
      }
    }
  },

  "pages": {
    "village_entrance": {
      "id": "village_entrance",
      "text": "You approach the peaceful village of Aldermere as the morning sun casts long shadows across cobblestone streets. Smoke rises from chimneys, and you hear the distant ring of hammer on anvil from the blacksmith's forge.",
      "background_id": "village_morning",

      "quest_triggers": {
        "discover_quests": ["blacksmith_apprentice", "merchant_caravan"],
        "story_flags_added": ["visited_village"]
      },

      "prompts": [
        {
          "text": "Visit the village blacksmith",
          "target_id": "village_blacksmith",
          "requirements": {},
          "quest_context": {
            "related_quests": ["blacksmith_apprentice"],
            "hint": "The sound of metalwork draws your attention"
          }
        },
        {
          "text": "Check the village gates",
          "target_id": "village_gates",
          "requirements": {},
          "quest_context": {
            "related_quests": ["merchant_caravan"],
            "hint": "A merchant's wagon waits by the gates"
          }
        },
        {
          "text": "Explore the village center",
          "target_id": "village_center",
          "requirements": {}
        },
        {
          "text": "Head to the tavern for information",
          "target_id": "village_tavern",
          "requirements": {}
        }
      ]
    },

    "village_blacksmith": {
      "id": "village_blacksmith",
      "text": "Master Gareth's forge is a hub of activity. The dwarf blacksmith looks up from his work, sweat glistening on his brow. Behind him, you notice an empty display case that seems to have once held something precious.",
      "background_id": "blacksmith_forge",

      "npcs": ["npc_gareth"],

      "quest_triggers": {
        "progress_quests": [
          {
            "quest_id": "blacksmith_apprentice",
            "objective_id": "talk_to_gareth",
            "progress_amount": 1,
            "condition": "first_visit"
          }
        ]
      },

      "quest_variants": {
        "blacksmith_apprentice": {
          "active_text": "Master Gareth works with renewed determination, but you can see the worry in his eyes about his missing hammer.",
          "completed_text": "Master Gareth beams with joy, his grandfather's hammer prominently displayed in the place of honor it deserves."
        }
      },

      "prompts": [
        {
          "text": "Talk to Master Gareth",
          "target_id": "talk_gareth",
          "requirements": {},
          "quest_interaction": true
        },
        {
          "text": "Browse his weapons",
          "target_id": "blacksmith_shop",
          "requirements": {}
        },
        {
          "text": "Ask about local rumors",
          "target_id": "blacksmith_rumors",
          "requirements": {}
        },
        {
          "text": "Leave the forge",
          "target_id": "village_center",
          "requirements": {}
        }
      ]
    },

    "village_gates": {
      "id": "village_gates",
      "text": "The village gates stand open to welcome travelers. A nervous-looking merchant tends to his wagon loaded with goods, occasionally glancing toward the dark forest beyond.",
      "background_id": "village_gates",

      "npcs": ["merchant_valdris"],

      "quest_triggers": {
        "progress_quests": [
          {
            "quest_id": "merchant_caravan",
            "objective_id": "accept_escort_duty",
            "progress_amount": 1,
            "condition": "accept_escort"
          }
        ]
      },

      "prompts": [
        {
          "text": "Approach the merchant",
          "target_id": "talk_merchant",
          "requirements": {},
          "quest_interaction": true
        },
        {
          "text": "Examine the forest path",
          "target_id": "forest_entrance",
          "requirements": {},
