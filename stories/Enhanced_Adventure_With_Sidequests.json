          }
        },
        {
          "text": "Return to village center",
          "target_id": "village_center",
          "requirements": {}
        }
      ]
    },

    "forest_entrance": {
      "id": "forest_entrance",
      "text": "The Dark Forest looms before you, its ancient trees creating a canopy so thick that little sunlight penetrates to the forest floor. You hear strange sounds echoing from within - could this be where the goblins make their lair?",
      "background_id": "dark_forest_entrance",

      "quest_triggers": {
        "progress_quests": [
          {
            "quest_id": "blacksmith_apprentice",
            "objective_id": "find_goblin_hideout",
            "progress_amount": 1,
            "condition": "first_exploration"
          }
        ]
      },

      "quest_variants": {
        "blacksmith_apprentice": {
          "active_text": "With Master Gareth's quest in mind, you scan the forest for signs of goblin activity. Fresh tracks lead deeper into the woods.",
          "completed_text": "You've already dealt with the goblin threat here. The forest seems much more peaceful now."
        }
      },

      "prompts": [
        {
          "text": "Follow the goblin tracks deeper into the forest",
          "target_id": "goblin_cave_entrance",
          "requirements": {
            "active_quests": ["blacksmith_apprentice"]
          },
          "quest_context": {
            "related_quests": ["blacksmith_apprentice"],
            "hint": "The tracks are fresh - the goblins passed this way recently"
          }
        },
        {
          "text": "Search for other paths",
          "target_id": "forest_exploration",
          "requirements": {}
        },
        {
          "text": "Return to the village",
          "target_id": "village_gates",
          "requirements": {}
        }
      ]
    },

    "goblin_cave_entrance": {
      "id": "goblin_cave_entrance",
      "text": "You discover a hidden cave entrance partially concealed by overgrown vines. Crude goblin totems mark the territory, and you can hear guttural voices echoing from within. The scent of wood smoke and something metallic - perhaps forged metal - drifts from the depths.",
      "background_id": "cave_entrance",

      "quest_triggers": {
        "progress_quests": [
          {
            "quest_id": "blacksmith_apprentice",
            "objective_id": "find_goblin_hideout",
            "progress_amount": 1,
            "condition": "discovery"
          }
        ]
      },

      "prompts": [
        {
          "text": "Enter the cave and confront the goblins",
          "target_id": "goblin_cave_interior",
          "requirements": {
            "active_quests": ["blacksmith_apprentice"]
          }
        },
        {
          "text": "Scout around the cave perimeter first",
          "target_id": "cave_scouting",
          "requirements": {}
        },
        {
          "text": "Return to get better equipment",
          "target_id": "forest_entrance",
          "requirements": {}
        }
      ]
    },

    "goblin_cave_interior": {
      "id": "goblin_cave_interior",
      "text": "Inside the goblin lair, crude weapons and stolen goods are scattered about. At the far end, a large goblin wearing a chieftain's crown brandishes a magnificently crafted hammer - clearly not of goblin make. This must be Master Gareth's stolen family heirloom!",
      "background_id": "goblin_lair",

      "combat": {
        "enemy": {
          "name": "Goblin Chief",
          "health": 45,
          "max_health": 45,
          "attack": 14,
          "defense": 6,
          "special_abilities": ["rage", "stolen_hammer_bonus"]
        },
        "victory": "hammer_recovery",
        "defeat": "forest_entrance"
      },

      "quest_triggers": {
        "progress_quests": [
          {
            "quest_id": "blacksmith_apprentice",
            "objective_id": "defeat_goblin_chief",
            "progress_amount": 1,
            "condition": "combat_victory"
          }
        ]
      },

      "prompts": [
        {
          "text": "Challenge the Goblin Chief to combat!",
          "target_id": "combat_goblin_chief",
          "requirements": {},
          "combat_encounter": true
        },
        {
          "text": "Try to negotiate for the hammer",
          "target_id": "goblin_negotiation",
          "requirements": {
            "stats_required": { "charisma": 15 }
          }
        },
        {
          "text": "Attempt to steal the hammer stealthily",
          "target_id": "stealth_attempt",
          "requirements": {
            "stats_required": { "stealth": 12 }
          }
        }
      ]
    },

    "hammer_recovery": {
      "id": "hammer_recovery",
      "text": "Victory! The Goblin Chief lies defeated, and Master Gareth's precious hammer is finally within your grasp. The craftsmanship is exquisite - you can see why it means so much to the old dwarf. Ancient runes are etched along the handle, still glowing faintly with residual magic.",
      "background_id": "victory_scene",

      "quest_triggers": {
        "complete_quests": ["blacksmith_apprentice"]
      },

      "rewards": {
        "items": ["Grandfather's Hammer"],
        "experience": 100,
        "story_flags": ["hammer_recovered"]
      },

      "prompts": [
        {
          "text": "Examine the hammer more closely",
          "target_id": "hammer_examination",
          "requirements": {},
          "quest_context": {
            "unlocks_quest": "ancient_forge_mystery",
            "hint": "The runes seem to tell a story..."
          }
        },
        {
          "text": "Search the goblin lair for other treasures",
          "target_id": "lair_treasure_hunt",
          "requirements": {}
        },
        {
          "text": "Return immediately to Master Gareth",
          "target_id": "return_to_gareth",
          "requirements": {}
        }
      ]
    },

    "hammer_examination": {
      "id": "hammer_examination",
      "text": "As you study the ancient runes on the hammer, they begin to glow brighter. The symbols seem to shift and rearrange themselves, revealing what appears to be a map or diagram. You make out references to 'the forge beneath' and 'awakening the ancient flame.' This hammer is more than just a tool - it's a key to something greater.",
      "background_id": "mysterious_discovery",

      "quest_triggers": {
        "discover_quests": ["ancient_forge_mystery"],
        "story_flags_added": ["ancient_runes_seen"]
      },

      "prompts": [
        {
          "text": "Memorize the rune pattern carefully",
          "target_id": "rune_memorization",
          "requirements": {
            "stats_required": { "intelligence": 10 }
          }
        },
        {
          "text": "Return to Gareth with this discovery",
          "target_id": "return_to_gareth_with_discovery",
          "requirements": {}
        }
      ]
    },

    "return_to_gareth_with_discovery": {
      "id": "return_to_gareth_with_discovery",
      "text": "Master Gareth's eyes widen as you return his hammer and describe the glowing runes. 'By my beard!' he exclaims. 'Those are the ancient smithing marks of the First Forge! Legend says there's a master forge hidden beneath our very village, built by the dwarf lords of old. If you've awakened the runes, perhaps... perhaps the old magics are stirring again.'",
